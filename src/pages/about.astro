---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getImage } from "astro:assets";
import Content2 from "@/components/widgets/Content2.astro";
import Values from "@/components/widgets/Values.astro";
import aboutImage from "@/assets/images/about-office.webp"; // Suggestion: Replace with a photo of your team or a library

const metadata = {
  title: "About Peak Peer",
  description:
    "Learn about the high schoolers behind Peak Peer and our mission to support middle school students.",
};

const values = [
  {
    title: "Relatability",
    description:
      "We were in middle school just a few years ago. We remember the stress, the social pressure, and exactly how the curriculum works.",
  },
  {
    title: "Mentorship",
    description:
      "Beyond just grades, we act as 'big siblings,' offering advice on navigating the transition to high school and extracurriculars.",
  },
  {
    title: "Clarity",
    description:
      "We explain concepts using language that makes sense to a 12-year-old, avoiding the stiff academic jargon often used by adults.",
  },
  {
    title: "Organization",
    description:
      "Half the battle in middle school is keeping track of assignments. We teach the systems and habits that keep us organized in high school.",
  },
  {
    title: "Growth Mindset",
    description:
      "We believe every student can improve. Our goal is to build confidence so students feel empowered to tackle difficult subjects alone.",
  },
  {
    title: "Community",
    description:
      "As local high schoolers, we care about our school district and want to see our younger peers succeed and lead.",
  },
];

const optimizedImage = await getImage({
  src: aboutImage,
  format: "webp",
});
---

<BaseLayout {metadata}>
  <link slot="head" rel="preload" href={optimizedImage.src} as="image" />

  <Content2
    title="Our Mission"
    description={[
      "Peak Peer was founded by a group of high school honors students who realized that the best people to help middle schoolers are those who just finished it. We bridge the gap between classroom teaching and real-world student success.",
      "Our mission is to provide high-quality, affordable tutoring while fostering a mentorship connection that traditional tutoring centers simply can't replicate. We're not just tutors; we're your neighbors, your peers, and your future high school teammates.",
    ]}
    tagline="About Our Team"
    image={aboutImage}
    imageAlt="High school students collaborating in a library"
    actions={[
      {
        text: "Inquire Now",
        href: "/contact",
        variant: "primary",
        icon: "lucide:mail",
      },
      {
        text: "Our Story",
        href: "#",
        variant: "secondary",
        icon: "lucide:arrow-right",
      },
    ]}
  />

  <Values
    items={values}
    columns={3}
    tagline="Our Core Principles"
    title="The Student-to-Student Difference"
    subtitle="What makes our approach more effective than traditional tutoring."
  />
</BaseLayout>
